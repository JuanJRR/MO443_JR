{
    "name": "MO443",
    "dockerComposeFile": [
        "../docker-compose.yml"
    ],
    "service": "development",

    "workspaceFolder": "/app",
    "customizations": {
        "vscode": {
            "userPortability": {
                "extensions": false
            },
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-toolsai.jupyter",
                "ms-toolsai.datawrangler",
                "njpwerner.autodocstring",
                "charliermarsh.ruff"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/bin/python",
                "python.analysis.extraPaths": ["/app/src"]
            }
        }
    }
}